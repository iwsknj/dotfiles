# Commands that are safe to run without approval.
prefix_rule(pattern = ["git"], decision = "allow")
prefix_rule(pattern = ["gh"], decision = "allow")
prefix_rule(pattern = ["npm"], decision = "allow")
prefix_rule(pattern = ["pnpm"], decision = "allow")
prefix_rule(pattern = ["npx"], decision = "allow")
prefix_rule(pattern = ["bundle"], decision = "allow")
prefix_rule(pattern = ["rails"], decision = "allow")
prefix_rule(pattern = ["bin/rspec"], decision = "allow")
prefix_rule(pattern = ["mise"], decision = "allow")
prefix_rule(pattern = ["make"], decision = "allow")
prefix_rule(pattern = ["docker"], decision = "allow")
prefix_rule(pattern = ["terraform"], decision = "allow")
prefix_rule(pattern = ["brew", "bundle"], decision = "allow")
prefix_rule(pattern = ["node"], decision = "allow")
prefix_rule(pattern = ["ruby"], decision = "allow")
prefix_rule(pattern = ["python"], decision = "allow")
prefix_rule(pattern = ["jq"], decision = "allow")
prefix_rule(pattern = ["sed"], decision = "allow")
prefix_rule(pattern = ["awk"], decision = "allow")
prefix_rule(pattern = ["xargs"], decision = "allow")
prefix_rule(pattern = ["ls"], decision = "allow")
prefix_rule(pattern = ["find"], decision = "allow")
prefix_rule(pattern = ["grep"], decision = "allow")
prefix_rule(pattern = ["rg"], decision = "allow")
prefix_rule(pattern = ["tree"], decision = "allow")
prefix_rule(pattern = ["cat"], decision = "allow")
prefix_rule(pattern = ["head"], decision = "allow")
prefix_rule(pattern = ["tail"], decision = "allow")
prefix_rule(pattern = ["wc"], decision = "allow")
prefix_rule(pattern = ["sort"], decision = "allow")
prefix_rule(pattern = ["diff"], decision = "allow")
prefix_rule(pattern = ["pwd"], decision = "allow")
prefix_rule(pattern = ["which"], decision = "allow")
prefix_rule(pattern = ["echo"], decision = "allow")
prefix_rule(pattern = ["mkdir"], decision = "allow")
prefix_rule(pattern = ["cp"], decision = "allow")
prefix_rule(pattern = ["mv"], decision = "allow")
prefix_rule(pattern = ["touch"], decision = "allow")
prefix_rule(pattern = ["chmod"], decision = "allow")

# Commands that should always be blocked.
prefix_rule(
    pattern = ["npm", ["uninstall", "remove"]],
    decision = "forbidden",
    justification = "Package removal is blocked by default.",
)
prefix_rule(
    pattern = ["pnpm", ["uninstall", "remove"]],
    decision = "forbidden",
    justification = "Package removal is blocked by default.",
)

# Destructive or external side-effect commands require approval.
prefix_rule(pattern = ["brew", "install"], decision = "prompt")
prefix_rule(pattern = ["git", "rm"], decision = "prompt")
prefix_rule(pattern = ["git", "reset", "--hard"], decision = "prompt")
prefix_rule(pattern = ["git", "clean"], decision = "prompt")
prefix_rule(pattern = ["git", "push"], decision = "prompt")
prefix_rule(pattern = ["git", "push", "--force"], decision = "prompt")
prefix_rule(pattern = ["git", "push", "-f"], decision = "prompt")
prefix_rule(pattern = ["git", "branch", "-D"], decision = "prompt")
prefix_rule(pattern = ["git", "stash", "drop"], decision = "prompt")
prefix_rule(pattern = ["npm", "install"], decision = "prompt")
prefix_rule(pattern = ["pnpm", "install"], decision = "prompt")
prefix_rule(pattern = ["curl"], decision = "prompt")
prefix_rule(pattern = ["wget"], decision = "prompt")
prefix_rule(pattern = ["curl", ["-X", "--request"]], decision = "prompt")
prefix_rule(pattern = ["curl", "-d"], decision = "prompt")
prefix_rule(pattern = ["curl", "--data"], decision = "prompt")
prefix_rule(pattern = ["curl", "-F"], decision = "prompt")
prefix_rule(pattern = ["wget", "--post-data"], decision = "prompt")
prefix_rule(pattern = ["wget", "--post-file"], decision = "prompt")
prefix_rule(pattern = ["sudo"], decision = "prompt")
prefix_rule(pattern = ["rm", "-rf"], decision = "prompt")
prefix_rule(pattern = ["rm", "-r"], decision = "prompt")
prefix_rule(pattern = ["rm", "-Rf"], decision = "prompt")
prefix_rule(pattern = ["rm", "-rF"], decision = "prompt")
prefix_rule(pattern = ["rm", "--recursive"], decision = "prompt")
prefix_rule(pattern = ["ssh"], decision = "prompt")
prefix_rule(pattern = ["scp"], decision = "prompt")
prefix_rule(pattern = ["terraform", "apply"], decision = "prompt")
prefix_rule(pattern = ["terraform", "destroy"], decision = "prompt")
prefix_rule(pattern = ["npm", "publish"], decision = "prompt")
